# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/wedding_db"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# Set to true when running in containers or behind reverse proxies
AUTH_TRUST_HOST="true"

# OAuth Providers
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook OAuth
# Facebook login is automatically enabled if these are provided. 
# You can force disable it with NEXT_PUBLIC_FACEBOOK_ENABLED="false"
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# Email Service (Resend)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@weddingmanagement.com"
EMAIL_FROM_NAME="{{WEDDING_NAME}} via Nupci" # Supports {{WEDDING_NAME}} variable
# Email address to receive contact form submissions
EMAIL_CONTACT_FORM="contact@yourdomain.com"

# Google reCAPTCHA v3 (for contact form spam protection)
# Get your keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# Crisp live chat (free tier: unlimited conversations, 2 agents, mobile app)
# Sign up at https://crisp.chat, create a website, copy the Website ID shown in
# Settings → Integrations → Chat.  When set, trial-mode users get a "Chat with us"
# button that opens a Crisp chat widget; you receive a push notification and can
# respond in real time from the Crisp dashboard or mobile app.
# Leave blank to fall back to the /contact page form.
NEXT_PUBLIC_CRISP_WEBSITE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# SMS and WhatsApp Service (Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
TWILIO_WEBHOOK_ENABLED="true"

# AI Configuration – WhatsApp auto-replies
# The app will automatically reply to guest WhatsApp messages using AI.
# Set AI_PROVIDER to "openai" (default) or "gemini", then provide the
# corresponding API key. You may set both keys; AI_PROVIDER selects which one
# is used.
#
# Twilio setup: in the Twilio console go to Messaging → Senders → your
# WhatsApp sender and set the inbound webhook URL to:
#   https://yourdomain.com/api/webhooks/twilio/inbound
AI_PROVIDER="openai"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"          # Latest fast/cheap model; alternatives: gpt-4.1-mini, gpt-4.1-nano
GEMINI_API_KEY="your-google-gemini-api-key"
GEMINI_MODEL="gemini-3-flash-preview"  # Latest fast model; alternatives: gemini-3.1-pro-preview, gemini-2.5-flash

# Vector Database (Neon) – AI document search (optional)
# When set, enables semantic search over uploaded wedding documents (RAG).
# Create a free Neon project at https://neon.tech, enable the pgvector extension,
# and paste the connection string here. The schema is pushed automatically on startup.
# The @prisma/vector-client must be generated before first use:
#   VECTOR_DATABASE_URL=<url> npx prisma generate --schema=prisma/vector/schema.prisma
#VECTOR_DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
# Set to "true" to enable the RAG re-index UI in the Master Admin dashboard.
# Must match whether VECTOR_DATABASE_URL is set.
#NEXT_PUBLIC_VECTOR_ENABLED="true"

# Application Configuration
NODE_ENV="development"
APP_URL="http://localhost:3000"
# Platform optimization: "cloudflare", "vercel", "docker", or "standard"
PLATFORM_OPTIMIZATION="standard"
# Commercial name of the platform
NEXT_PUBLIC_COMMERCIAL_NAME="Nupci"

# ── Caching (guest-facing hot paths) ─────────────────────────────────────────
#
# RSVP_CACHE_TTL_HOURS
#   Controls TWO runtime caches for the /rsvp/ page:
#     1. Server in-memory per-wedding cache (lib/cache/rsvp-page.ts)
#     2. Vercel CDN Cache-Control s-maxage (when PLATFORM_OPTIMIZATION=vercel)
#   Explicit invalidation fires immediately on template / settings changes.
#   NOTE: The Next.js ISR 'revalidate' constant in page.tsx is a static build-
#   time literal (Next.js requirement); if you change this value, also update
#   'export const revalidate' in src/app/(public)/rsvp/[token]/page.tsx.
#   Default: 1 hour
RSVP_CACHE_TTL_HOURS="1"
#
# SHORT_URL_CACHE_TTL_HOURS
#   Controls TWO runtime caches for the /inv/ short-URL redirect page:
#     1. Server in-memory short-URL → token resolution cache (lib/short-url.ts)
#     2. Vercel CDN Cache-Control s-maxage (when PLATFORM_OPTIMIZATION=vercel)
#   Short URL codes are permanent, so a long TTL is fine.
#   NOTE: If you change this, also update 'export const revalidate' in
#   src/app/(public)/inv/[initials]/[shortCode]/page.tsx.
#   Default: 24 hours
SHORT_URL_CACHE_TTL_HOURS="24"

# Redis (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# Redis for admin/planner server-side caching (optional, graceful fallback to DB if unset)
# Used to cache wedding details, stats, upcoming tasks, and favicons for fast /admin and /planner page loads
WEDDING_REDIS_REDIS_URL="redis://localhost:6379"

# Notifications Cache (optional)
# How many notifications to cache in Redis per wedding
NOTIFICATIONS_CACHE_SIZE="100"

# Master Admin Configuration
# Comma-separated list of email addresses that should have master admin access
# Master admins can manage wedding planners and view all weddings
MASTER_ADMIN_EMAILS="admin@example.com,admin2@example.com"

# How often (in minutes) to re-validate a logged-in user's role against the database.
# Lower values detect permission changes faster; higher values reduce DB load.
# Default: 60 (1 hour)
ROLE_REVALIDATION_INTERVAL_MINUTES="60"

# Monitoring & Logging
LOG_LEVEL="info"
UPTIME_ROBOT_WEBHOOK="your-uptime-robot-webhook-url"

# Backup Configuration
BACKUP_STORAGE_URL="your-backup-storage-url"
BACKUP_RETENTION_DAYS="30"

# Vercel Blob Storage (Optional)
# When set, file uploads will use Vercel Blob Storage instead of local filesystem
# Get this token from your Vercel project settings: https://vercel.com/docs/storage/vercel-blob
#BLOB_READ_WRITE_TOKEN="your-vercel-blob-read-write-token"

# CDN base URL for static assets (videos, example templates, etc.)
# Used by landing page videos and the invitation builder example templates
NEXT_PUBLIC_CDN_STORAGE="https://cdn.nupci.com"

# ── Google Photos Integration ─────────────────────────────────────────────────
#
# Enables wedding photo gallery integration with Google Photos.
# The same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET used for auth are reused.
# Required additional OAuth scopes:
#   https://www.googleapis.com/auth/photoslibrary
#   https://www.googleapis.com/auth/photoslibrary.sharing
#
# In the Google Cloud Console, make sure these scopes are added to your OAuth
# consent screen and that APP_URL/api/admin/gallery/google-photos/callback
# is listed as an authorized redirect URI.
#
# No additional environment variables are required beyond GOOGLE_CLIENT_ID and
# GOOGLE_CLIENT_SECRET already defined above.
#
# Tokens are stored per-wedding in the database (google_photos_*_token fields).
# For production, consider encrypting these tokens at rest.

# HyperDX Observability (https://hyperdx.io)
# HYPERDX_API_KEY is used by the server-side OpenTelemetry exporter to send
# traces (including Prisma DB spans) to HyperDX's OTLP endpoint.
# NEXT_PUBLIC_HYPERDX_API_KEY is used by the browser SDK for frontend tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT overrides the default HyperDX ingest URL (optional).
HYPERDX_API_KEY=
NEXT_PUBLIC_HYPERDX_API_KEY=

# ── Quotes & Finances ────────────────────────────────────────────────────────
#
# Liveblocks (https://liveblocks.io)
# Used for real-time collaborative contract editing (YJS hosted backend).
# Create a project at liveblocks.io → Settings → API Keys → Secret key.
LIVEBLOCKS_SECRET=sk_...

# DocuSeal (https://www.docuseal.com)
# Used for legally-binding eSignature on contracts, with embedded signing widget.
# Cloud SaaS: sign up at docuseal.com → Settings → API → API Token.
# Self-hosted: point DOCUSEAL_API_URL at your own instance.
DOCUSEAL_API_KEY=

# DocuSeal API base URL (optional — defaults to https://api.docuseal.com).
# Override this when using a self-hosted DocuSeal instance.
# Example for self-hosted: https://docuseal.yourdomain.com/api
#DOCUSEAL_API_URL=https://api.docuseal.com

# DocuSeal webhook secret (optional but recommended).
# Set this to verify webhook payloads from DocuSeal.
# In DocuSeal dashboard: Settings → Webhooks → create a webhook for:
#   https://yourdomain.com/api/webhooks/docuseal
# Events to subscribe: form.completed, submission.completed
#DOCUSEAL_WEBHOOK_SECRET=your-webhook-secret

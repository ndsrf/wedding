{
  "name": "wedding-management-mvp",
  "version": "1.4.0",
  "private": true,
  "workspaces": [
    "stubs/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit --coverage --coverageThreshold='{}'",
    "test:integration": "jest --testPathPatterns=tests/integration --coverage --coverageThreshold='{}'",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "version": "npm run changelog && git add CHANGELOG.md",
    "release": "npm version",
    "db:generate": "prisma generate && prisma generate --schema=prisma/vector/schema.prisma",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "node -r dotenv/config node_modules/prisma/build/index.js generate && node -r dotenv/config node_modules/prisma/build/index.js generate --schema=prisma/vector/schema.prisma"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@auth/prisma-adapter": "^2.11.1",
    "@google/genai": "^1.44.0",
    "@hyperdx/browser": "^0.22.0",
    "@opentelemetry/instrumentation-undici": "^0.23.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@prisma/instrumentation": "^7.5.0",
    "@react-email/components": "^1.0.0",
    "@vercel/analytics": "^2.0.0",
    "@vercel/blob": "^2.0.0",
    "@vercel/otel": "^2.1.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.116",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^3.0.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "mime": "^4.1.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.7.0",
    "node-sql-parser": "^5.4.0",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.17.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-google-recaptcha-v3": "^1.11.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "resend": "^6.0.0",
    "sharp": "^0.34.5",
    "twilio": "^5.12.0",
    "winston": "^3.18.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/exceljs": "^1.0.0",
    "@types/html2canvas": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/mime": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.2.0",
    "postcss": "^8.4.49",
    "prisma": "^7.3.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "@babel/runtime": ">=7.26.10",
    "@opentelemetry/resources": "^2.0.0",
    "hono": "^4.12.7",
    "https-proxy-agent": "^8.0.0",
    "twilio": {
      "https-proxy-agent": "^7.0.0"
    },
    "serialize-javascript": "^7.0.4",
    "test-exclude": "^8.0.0"
  }
}

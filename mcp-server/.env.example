# URL of your Nupci platform instance
NUPCI_URL=https://your-domain.com

# API key generated from the platform (wedding_admin or planner role)
NUPCI_API_KEY=npci_your_key_here

# Role: "wedding_admin" (default) or "planner"
# Use "wedding_admin" if you generated the key as a wedding couple.
# Use "planner" if you generated the key as a wedding planner.
NUPCI_ROLE=wedding_admin

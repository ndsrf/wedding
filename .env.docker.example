# Docker Environment Configuration
# Copy this file to .env and fill in the values before running docker-compose

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=wedding
POSTGRES_PASSWORD=your-secure-database-password-here
POSTGRES_DB=wedding_db

# ============================================
# NextAuth Configuration
# ============================================
# IMPORTANT: Set this to your actual domain in production
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32
# Required when running in containers or behind reverse proxies
AUTH_TRUST_HOST=true

# ============================================
# Application URLs
# ============================================
# The public URL where your app is accessible
APP_URL=https://your-domain.com

# ============================================
# RSVP Page Cache
# ============================================
# Caching – guest-facing hot paths
# ============================================
# RSVP page: in-memory cache TTL AND ISR revalidation interval (in hours).
# Explicit invalidation still fires immediately on template / settings changes.
RSVP_CACHE_TTL_HOURS=1
# Short URL (/inv/) resolver: in-memory cache TTL AND ISR interval (in hours).
# Short URL codes are permanent so a long TTL is fine.
SHORT_URL_CACHE_TTL_HOURS=24

# ============================================
# OAuth Providers
# ============================================
# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (https://developers.facebook.com/)
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ============================================
# Email Service (Resend)
# ============================================
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Wedding Management Platform

# ============================================
# SMS and WhatsApp Service (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_ENABLED=true

# ============================================
# AI Configuration – NupciBot and document search
# ============================================
# Set AI_PROVIDER to "openai" (default) or "gemini", then provide the
# corresponding API key. The same provider is used for chat and embeddings.
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# ============================================
# Vector Database – AI Document Search (Optional)
# ============================================
# Neon PostgreSQL with pgvector for semantic document search (RAG).
# Create a project at https://neon.tech and enable the pgvector extension.
# The schema is pushed automatically on startup when this variable is set.
# Generate the vector Prisma client before first use:
#   VECTOR_DATABASE_URL=<url> npx prisma generate --schema=prisma/vector/schema.prisma
# VECTOR_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
# Set to "true" to show the RAG re-index UI in the Master Admin dashboard.
# NEXT_PUBLIC_VECTOR_ENABLED=true

# ============================================
# Optional: Redis for Caching
# ============================================
# Uncomment if using Redis
# REDIS_URL=redis://redis:6379
# Admin/planner server-side cache: wedding details, stats, tasks, and favicons (optional, graceful fallback to DB if unset)
# WEDDING_REDIS_REDIS_URL=redis://redis:6379
# How many notifications to cache in Redis per wedding (default: 100)
# NOTIFICATIONS_CACHE_SIZE=100

# ============================================
# Auth
# ============================================
# How often (in minutes) to re-validate a logged-in user's role against the database.
# Lower values detect permission changes faster; higher values reduce DB load.
# Default: 60 (1 hour)
# ROLE_REVALIDATION_INTERVAL_MINUTES=60

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Monitoring (Optional)
# ============================================
UPTIME_ROBOT_WEBHOOK=your-uptime-robot-webhook-url

# ============================================
# Backup Configuration (Optional)
# ============================================
BACKUP_STORAGE_URL=your-backup-storage-url
BACKUP_RETENTION_DAYS=30

# CDN base URL for static assets (videos, example templates, etc.)
NEXT_PUBLIC_CDN_STORAGE="https://cdn.nupci.com"

# Crisp live chat widget (https://crisp.chat) — optional, omit to disable
# NEXT_PUBLIC_CRISP_WEBSITE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# HyperDX Observability (https://hyperdx.io)
HYPERDX_API_KEY=
NEXT_PUBLIC_HYPERDX_API_KEY=
